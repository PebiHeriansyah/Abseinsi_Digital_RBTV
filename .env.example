APP_NAME="Absensi RBTV"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =========================================================
# DATABASE (lokal: MySQL, production: PostgreSQL Supabase)
# =========================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=absensi_rbtv
DB_USERNAME=root
DB_PASSWORD=

# Untuk production (Supabase PostgreSQL) — uncomment & isi:
# DB_CONNECTION=pgsql
# DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# =========================================================
# FILESYSTEM DISK
# Lokal     : FILESYSTEM_DISK=public
# Production: FILESYSTEM_DISK=supabase
# =========================================================
FILESYSTEM_DISK=public

QUEUE_CONNECTION=database
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =========================================================
# SUPABASE STORAGE (S3-compatible)
# Isi setelah membuat project di https://supabase.com
# Dapatkan dari: Project Settings > Storage > S3 Connection
# =========================================================
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

SUPABASE_S3_KEY=
SUPABASE_S3_SECRET=
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_BUCKET=absensi-rbtv
SUPABASE_S3_ENDPOINT=https://[project-ref].supabase.co/storage/v1/s3
SUPABASE_STORAGE_URL=https://[project-ref].supabase.co/storage/v1/object/public

VITE_APP_NAME="${APP_NAME}"
